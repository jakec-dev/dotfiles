[colors]
background = #282a36
selection = #44475a
foreground = #bcc2cd
comment = #6272a4
primary = #8be9fd
secondary = #ff79c6
alert = #ff5555
success = #50fa7b
app = #ffb86c

[settings]
screenchange-reload = true
format-padding = 1
format-foreground = ${colors.foreground}
format-underline = ${colors.foreground}
format-background = ${colors.selection}

[global/wm]
margin-top = 0
margin-bottom = 0

[bar/mybar]
width = 100%
height = 32
background = ${colors.background}
foreground = ${colors.foreground}
line-size = 3
line-color = ${colors.primary}
border-size = 0
padding-left = 0
padding-right = 2
module-margin-left = 0
module-margin-right = 1
font-0 = Source Code Pro,Source Code Pro Medium:style=Medium,Regular:pixelsize=10;3
font-1 = Font Awesome 5 Brands:style=Regular:pixelsize=10;3
font-2 = Font Awesome 5 Free:style=Solid:pixelsize=10;3
font-3 = Font Awesome 5 Free:style=Regular:pixelsize=10;3
modules-left = app-launcher i3 new-workspace xwindow
modules-center = news
modules-right =  terminal file-manager notes bluetooth redshift wifi vpn package-updates trash volume time power-menu
wm-restack = i3
cursor-click = pointer
cursor-scroll = ns-resize

[module/app-launcher]
type = custom/script
exec = echo 
click-left = rofi -modi drun, run -show drun -show-icons -display-drun "Search"
format-underline =
format-background =

[module/i3]
type = internal/i3
pin-workspaces = true
format = <label-state> <label-mode>
format-padding = 0
format-underline =
format-background =
index-sort = true
wrapping-scroll = false
label-mode-padding = 1
label-mode-foreground = ${colors.background}
label-mode-background = ${colors.primary}
label-focused = %index%
label-focused-background = ${colors.selection}
label-focused-foreground = ${colors.foreground}
label-focused-underline= ${colors.primary}
label-focused-padding = 1
label-unfocused = %index%
label-unfocused-padding = 1
label-visible =%index%
label-visible-background = ${self.label-focused-background}
label-visible-underline = ${self.label-focused-underline}
label-visible-padding = ${self.label-focused-padding}
label-urgent = %index% 
label-urgent-background = ${colors.alert}
label-urgent-padding = 1
label-separator = |

[module/new-workspace]
type = custom/script
exec = echo 
click-left = $SCRIPTS_HOME/polybar/new-workspace.sh
format-underline =
format-background =

[module/xwindow]
type = internal/xwindow
label = >> %title%
label-maxlen = 50
format = <label>
format-padding = 0
format-underline =
format-background =

[module/news]
type = custom/script
exec = $SCRIPTS_HOME/polybar/news/news-feed.sh
interval = 180
click-left = $SCRIPTS_HOME/polybar/news/news-feed.sh url
click-middle = $SCRIPTS_HOME/polybar/news/news-feed.sh download
click-right = $TERMINAL --class floatingKitty -e newsboat &
format-prefix = " " 
format-underline =
format-background =

[module/open-web]
type = custom/script
exec = echo  web
click-left = $BROWSER &
format-foreground = ${colors.app}
format-underline = ${colors.app}

[module/terminal]
type = custom/script
exec = echo  terminal
click-left = $SCRIPTS_HOME/polybar/open-terminal.sh
format-foreground = ${colors.app}
format-underline = ${colors.app}

[module/calculator]
type = custom/script
exec = echo  calculator
click-left = rofi -show calc -modi calc -no-show-match -no-sort -display-calc "" &
format-foreground = ${colors.app}
format-underline = ${colors.app}

[module/file-manager]
type = custom/script
exec = echo  files
click-left = $SCRIPTS_HOME/polybar/open-files.sh
format-foreground = ${colors.app}
format-underline = ${colors.app}

[module/notes]
type = custom/script
exec = echo  notes
click-left = $SCRIPTS_HOME/polybar/open-vimwiki.sh 
format-foreground = ${colors.app}
format-underline = ${colors.app}

[module/bluetooth]
type = custom/script
exec = rofi-bluetooth --status
interval = 5 
click-left = rofi-bluetooth & 
format-foreground = #8be9fd

[module/redshift]
type = custom/script
exec = $SCRIPTS_HOME/polybar/redshift.sh
click-left = $SCRIPTS_HOME/polybar/redshift.sh toggle
interval = 5
format = <label>

[module/wifi]
type = internal/network
interface = wlp6s0
click-left = $SCRIPTS_HOME/polybar/network_manager.sh &
interval = 3
format = <label>
label-connected = 
label-connected-foreground = ${colors.success}

[module/vpn]
type = custom/script
exec = $SCRIPTS_HOME/polybar/vpn.sh
click-right = $SCRIPTS_HOME/polybar/vpn.sh --toggle-connection &
click-left = $SCRIPTS_HOME/polybar/vpn.sh --location-menu &
interval = 5
format = <label>

[module/package-updates]
type = custom/script
exec = $SCRIPTS_HOME/polybar/pac-yay-updates.sh
tail = true
click-left = $SCRIPTS_HOME/polybar/pac-yay-updates.sh update
interval = 5

[module/trash]
type = custom/script
exec = $SCRIPTS_HOME/polybar/trash.sh
interval = 5
click-left = $TERMINAL --class=floatingKitty bash -c "$SCRIPTS_HOME/system/empty-trash.sh"

[module/volume]
type = custom/script
tail = true
exec = $SCRIPTS_HOME/polybar/volume.sh --icons-volume " ," --icon-muted "" --sink-nicknames-from "device.description" --sink-nickname "alsa_output.pci-0000_00_1f.3.analog-stereo: " listen
click-right = $TERMINAL -e pulsemixer &
click-left = $SCRIPTS_HOME/polybar/volume.sh togmute
scroll-up = $SCRIPTS_HOME/polybar/volume.sh --volume-max 130 up
scroll-down = $SCRIPTS_HOME/polybar/volume.sh --volume-max 130 down

[module/time]
type = internal/date
interval = 1
date = %a %d/%m
date-alt = %a, %d %b %Y
time = %I:%M %p
time-alt = %I:%M %p
label = %date% | %time%

[module/power-menu]
type = custom/script
exec = echo 
click-left = rofi -show power-menu -modi power-menu:$SCRIPTS_HOME/polybar/power-menu.sh
format-foreground = ${colors.alert}
format-underline = ${colors.alert}
format-background = 

; vim:ft=dosini
