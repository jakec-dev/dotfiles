font-2 = Font Awesome 5 Free:style=Solid:pixelsize=10;3
font-3 = Font Awesome 5 Free:style=Regular:pixelsize=10;3
modules-left = app-launcher bspwm new-workspaces xwindow
;modules-right = filesystem xbacklight alsa pulseaudio xkeyboard memory cpu wlan eth battery temperature date powermenu
modules-right =  terminal file-manager notes tui tasks-inbox package-updates dotfiles trash alerts redshift volume battery time power-menu
cursor-click = pointer
cursor-scroll = ns-resize
tray-position = right
wm-restack = bspwm

[bar/hdmi]
