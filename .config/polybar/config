[colors]
background = #282a36
selection = #44475a
foreground = #bcc2cd
comment = #6272a4
primary = #8be9fd
secondary = #ff79c6
alert = #ff5555
success = #50fa7b
warning = #ffb86c
app = ${colors.primary}

[settings]
screenchange-reload = true
format-padding = 1
format-foreground = ${colors.foreground}
format-underline = ${colors.foreground}
format-background = ${colors.selection}

[global/wm]
margin-top = 0
margin-bottom = 0

[bar/screen]
monitor = eDP1
width = 100%
height = 32
background = ${colors.background}
foreground = ${colors.foreground}
line-size = 3
line-color = ${colors.primary}
border-size = 0
padding-left = 0
padding-right = 2
