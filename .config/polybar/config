tail = true
click-left = /home/jake/.config/polybar/pac-yay-updates.sh update
interval = 5

[module/trash]
type = custom/script
exec = ~/.config/polybar/trash.sh
interval = 5
click-left = bspc rule -a \* -o state=floating && kitty bash -c "~/.config/polybar/empty-trash.sh"

[module/tasks-inbox]
type = custom/script
exec = /home/jake/.config/polybar/tasks.sh
interval = 3
click-left = bspc rule -a \* -o state=floating && kitty bash -c "taskwarrior-tui --report=in"

[module/dotfiles]
type = custom/script
