# Datetime settings
weekstart=Monday

# Default values
#default.project=Inbox

# Urgency coefficients
urgency.user.tag.urgent.coefficient=10.0
urgency.user.tag.rnd.coefficient=-2
urgency.user.tag.later.coefficient=-6.0

# Contexts
alias.@=context
context.study=project:Education or +study
context.home=project:Personal or +home
context.work=project:Work or +work

# Inbox report
report.in.columns           = id,description
report.in.description       = Inbox
report.in.filter            = status:pending (+inbox)
report.in.labels            = ID,Description

# UDAs
uda.estimate.type=numeric
uda.estimate.label=Estimate

# Taskwarrior-tui
uda.taskwarrior-tui.task-report.next.filter=status:pending
uda.taskwarrior-tui.shortcuts.9=~/.config/taskwarrior-tui/open-note.sh
uda.taskwarrior-tui.shortcuts.1=~/.config/taskwarrior-tui/task-inbox.sh
uda.taskwarrior-tui.shortcuts.2=~/.config/taskwarrior-tui/filter-all-child-tasks.sh

# Reviewing tasks
uda.reviewed.type=date
uda.reviewed.label=Reviewed
report._reviewed.description=Tasksh review report.  Adjust the filter to your needs.
report._reviewed.columns=uuid
report._reviewed.sort=reviewed+,modified+
report._reviewed.filter=( reviewed.none: or reviewed.before:now-6days ) and ( +PENDING or +WAITING )
report.next.columns=id,start.age,entry.age,depends,priority,project,tags,recur,scheduled.countdown,due.relative,until.remaining,estimate,description,urgency
report.next.labels=ID,Active,Age,Deps,P,Project,Tag,Recur,S,Due,Until,Est,Description,Urg

